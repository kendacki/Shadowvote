{
  "name": "shadowvote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:vite": "vite",
    "build": "next build",
    "build:vite": "tsc -b && vite build",
    "preview": "next start",
    "preview:vite": "vite preview",
    "start": "next start",
    "compile:contract": "node scripts/compact-compile.mjs",
    "zkir:copy": "node -e \"const fs=require('fs');const path=require('path');const d=path.join('build','zkir');const a=path.join(d,'vote.zkir');const b=path.join(d,'vote.bzkir');if(fs.existsSync(a)&&!fs.existsSync(b))fs.copyFileSync(a,b);\"",
    "zk:public": "node scripts/copy-zk-to-public.mjs",
    "deploy": "tsx scripts/deploy.ts",
    "start-proof-server": "docker compose up proof-server"
  },
