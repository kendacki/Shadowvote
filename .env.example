# Copy to `.env` in the project root (never commit `.env`).

# --- Local private state DB (Level provider; min 16 characters) ---
MIDNIGHT_PRIVATE_STATE_PASSWORD=

# --- Wallet (pays deployment fees / gas via DUST) ---
# 64 hex characters = 32-byte seed for HDWallet.fromSeed (Lace export or generated).
# This is your secret; keep it offline and never commit it.
MIDNIGHT_SEED_HEX=

# --- Network (Midnight JS global network id; default matches Preprod tutorial) ---
MIDNIGHT_NETWORK_ID=preprod

# --- Indexer + node (override only if you use a different testnet / private stack) ---
MIDNIGHT_INDEXER_HTTPS=https://indexer.preprod.midnight.network/api/v3/graphql
MIDNIGHT_INDEXER_WSS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
MIDNIGHT_NODE_RPC=https://rpc.preprod.midnight.network

# --- Local proof server (must match `docker compose` / `start-proof-server`) ---
PROOF_SERVER_URL=http://127.0.0.1:6300

# --- ShadowVote voter Merkle registry (must match between deploy and app) ---
# `npm run deploy` sets constructor `voterRoot.field` to `computeVoterRegistryRootField(leaves)` for this list.
# Use the same comma-separated 32-byte LEAF hashes (voterLeafHash outputs), index order = Merkle indices 0, 1, …
# - VOTER_REGISTRY_LEAVES_HEX — read by deploy (Node); optional duplicate for CI.
# - NEXT_PUBLIC_VOTER_REGISTRY_LEAVES_HEX — read by the browser for proofs; deploy falls back to this if unset.
# If both unset: single dev leaf = hash of the all-zero 32-byte secret.
# VOTER_REGISTRY_LEAVES_HEX=
# NEXT_PUBLIC_VOTER_REGISTRY_LEAVES_HEX=0xabc...,0xdef...

# --- Next.js frontend (browser) ---
# Logical network tier for UI (`NetworkBanner`). Falls back to NEXT_PUBLIC_MIDNIGHT_NETWORK_ID if unset.
# Examples: local | testnet | preprod | mainnet
# NEXT_PUBLIC_MIDNIGHT_NETWORK=preprod
NEXT_PUBLIC_MIDNIGHT_NETWORK_ID=preprod
# Optional: raw token key string for tNight in `getUnshieldedBalances()`; if unset, balances are summed.
NEXT_PUBLIC_NIGHT_TOKEN_KEY=

# ShadowVote dashboard: deployed contract ledger address (hex). Required for indexer calls.
NEXT_PUBLIC_SHADOWVOTE_CONTRACT_ADDRESS=
NEXT_PUBLIC_MIDNIGHT_PRIVATE_STATE_PASSWORD=

# Base URL (path or absolute) where `npm run zk:public` artifacts are served: `public/shadowvote-zk` → `/shadowvote-zk`
NEXT_PUBLIC_SHADOWVOTE_ZK_BASE=/shadowvote-zk
