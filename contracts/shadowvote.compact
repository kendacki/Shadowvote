// =============================================================================
// ShadowVote — Open DAO governance (Midnight Compact)
// =============================================================================
// Public state: per-proposal tallies and spent nullifiers. Anyone with the
// private voter secret can produce a unique nullifier per proposal; double
// votes are rejected on-chain. Frontend gates participation by tNIGHT balance.
// =============================================================================

pragma language_version 0.22;

import CompactStandardLibrary;

// -----------------------------------------------------------------------------
// Public ledger
// -----------------------------------------------------------------------------
export ledger proposals: Map<Uint<32>, Uint<32>>;
export ledger nullifiers: Set<Bytes<32>>;

// -----------------------------------------------------------------------------
// Constructor
// -----------------------------------------------------------------------------
constructor() {}

// -----------------------------------------------------------------------------
// Private witnesses
// -----------------------------------------------------------------------------
witness voterSecret(): Bytes<32>;

// -----------------------------------------------------------------------------
// Internal circuits
// -----------------------------------------------------------------------------
circuit computeNullifier(secret: Bytes<32>, proposalId: Uint<32>): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>([
    pad(32, "shadowvote:nullifier:v1"),
    secret,
    proposalId as Bytes<32>,
  ]);
}

// -----------------------------------------------------------------------------
// Exported transitions
// -----------------------------------------------------------------------------
export circuit vote(proposalId: Uint<32>): [] {
  const pid = disclose(proposalId);
  const sk = voterSecret();
  const nullifier = disclose(computeNullifier(sk, pid));
  assert(!nullifiers.member(nullifier), "ShadowVote: nullifier already spent");

  nullifiers.insert(nullifier);

  if (proposals.member(pid)) {
    const currentCount = proposals.lookup(pid);
    proposals.insert(pid, (currentCount + 1) as Uint<32>);
  } else {
    proposals.insert(pid, 1);
  }
}
